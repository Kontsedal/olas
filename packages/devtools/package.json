{
  "name": "@olas/devtools",
  "version": "0.0.0",
  "description": "Olas in-app devtools panel — controller tree, cache timeline, mutation log",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@olas/core": "workspace:^",
    "@olas/react": "workspace:^",
    "react": ">=18"
  },
  "devDependencies": {
    "@olas/core": "workspace:^",
    "@olas/react": "workspace:^",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
