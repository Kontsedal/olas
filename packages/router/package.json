{
  "name": "@kontsedal/olas-router",
  "version": "0.0.6",
  "description": "Olas router bridge — scopes + a generic Bridge component for wiring any client-side router (TanStack Router, React Router v6) into the controller tree.",
  "keywords": [
    "olas",
    "controller-tree",
    "signals",
    "reactive",
    "state-management",
    "router",
    "tanstack-router",
    "react-router"
  ],
  "license": "MIT",
  "author": "Bohdan Kontsedal <kontsedalbohdan@gmail.com>",
  "homepage": "https://github.com/Kontsedal/olas/tree/main/packages/router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kontsedal/olas.git",
    "directory": "packages/router"
  },
  "bugs": {
    "url": "https://github.com/Kontsedal/olas/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@kontsedal/olas-core": "workspace:^",
    "react": ">=18"
  },
  "devDependencies": {
    "@kontsedal/olas-core": "workspace:^",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
