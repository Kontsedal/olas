{
  "name": "@kontsedal/olas-realtime",
  "version": "0.0.14",
  "description": "Olas realtime composables — useRealtimePatcher and defineLiveStream over a pluggable RealtimeService.",
  "keywords": [
    "olas",
    "controller-tree",
    "signals",
    "reactive",
    "state-management",
    "realtime",
    "websocket",
    "sse",
    "cache-patching"
  ],
  "license": "MIT",
  "author": "Bohdan Kontsedal <kontsedalbohdan@gmail.com>",
  "homepage": "https://github.com/Kontsedal/olas/tree/main/packages/realtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kontsedal/olas.git",
    "directory": "packages/realtime"
  },
  "bugs": {
    "url": "https://github.com/Kontsedal/olas/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@kontsedal/olas-core": "workspace:^"
  },
  "devDependencies": {
    "@kontsedal/olas-core": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
