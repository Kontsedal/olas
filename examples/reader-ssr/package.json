{
  "name": "@olas/example-reader-ssr",
  "version": "0.0.0",
  "private": true,
  "description": "React + SSR example — infinite feed with dehydrate/hydrate, useSuspendOnHidden, persisted reading progress",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build": "pnpm run build:client && pnpm run build:server",
    "serve": "node server.mjs",
    "preview": "pnpm run build && pnpm run serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@olas/core": "workspace:^",
    "@olas/persist": "workspace:^",
    "@olas/react": "workspace:^",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@preact/signals-core": "^1.14.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
