{
  "name": "@olas/example-reader-ssr",
  "version": "0.0.0",
  "private": true,
  "description": "React + SSR example — infinite feed with dehydrate/hydrate, useSuspendOnHidden, persisted reading progress",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build": "pnpm run build:client && pnpm run build:server",
    "serve": "node server.mjs",
    "preview": "pnpm run build && pnpm run serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@olas/core": "workspace:^",
    "@olas/react": "workspace:^",
    "@olas/persist": "workspace:^",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@preact/signals-core": "^1.8.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.21.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
