{
  "name": "olas",
  "private": true,
  "version": "0.0.0",
  "description": "Olas — controller-tree architecture for browser apps",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "NODE_ENV=production pnpm -r --filter \"./packages/*\" build",
    "build:dev": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" --filter \"./examples/*\" typecheck",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "wiki:lint": "tsx scripts/wiki-lint.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
